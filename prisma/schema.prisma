// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Ajans hizmetleri (örn: Web Tasarım, Dijital Pazarlama)
model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  icon        String?  // ikon adı veya emoji
  order       Int      @default(0)
  projects   Project[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Portföy / referans projeleri
model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  imageUrl    String?  // referans logosu
  clientName  String?
  projectUrl  String?
  category    String?  // filtre için: Sağlık, E-Ticaret, Turizm vb.
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Blog yazıları
model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   // HTML veya markdown
  imageUrl    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Partner / rozet logoları (kayan bant)
model Partner {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin kullanıcıları
model User {
  id        String    @id @default(cuid())
  username  String    @unique
  password  String    // bcrypt hash
  name      String
  role      String    @default("editor") // admin | editor | viewer
  active    Boolean   @default(true)
  sessions  Session[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Oturum tokenları
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// İletişim formundan gelen mesajlar
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
